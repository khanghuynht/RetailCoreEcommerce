    @model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<!-- ── Hero ─────────────────────────────────────────────────── -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <span class="hero-badge mb-3 d-inline-block">New Arrivals 2026</span>
                <h1 class="mb-4">
                    Discover <br />
                    <span style="color:var(--accent)">Premium Products</span><br />
                    At Great Prices
                </h1>
                <p class="lead mb-4 opacity-75">
                    Shop the latest collection across all categories.
                    Quality you can trust, prices you'll love.
                </p>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-accent btn-lg me-3">
                    Shop Now <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="col-lg-6 d-none d-lg-flex justify-content-end">
                <i class="bi bi-bag-heart" style="font-size:10rem; opacity:.15;"></i>
            </div>
        </div>
    </div>
</section>

<!-- ── Categories ────────────────────────────────────────────── -->
@if (Model.Categories.Count > 0)
{
    <section class="py-5 bg-white">
        <div class="container">
            <h2 class="section-title">Shop by Category</h2>
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3">
                @foreach (var cat in Model.Categories)
                {
                    <div class="col">
                        <a asp-controller="Shop"
                           asp-action="Index"
                           asp-route-categoryId="@cat.Id"
                           class="category-card">
                            <div class="cat-icon">
                                <i class="bi bi-tag-fill" style="color:var(--accent);"></i>
                            </div>
                            <div class="cat-name">@cat.Name</div>
                            @if (!string.IsNullOrEmpty(cat.Description))
                            {
                                <small class="text-muted">@cat.Description</small>
                            }
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- ── Featured Products ─────────────────────────────────────── -->
@if (Model.FeaturedProducts.Count > 0)
{
    <section class="py-5" style="background:var(--light-bg);">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="section-title mb-0">Featured Products</h2>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                @foreach (var product in Model.FeaturedProducts)
                {
                    <div class="col">
                        @await Html.PartialAsync("_ProductCard", product)
                    </div>
                }
            </div>
        </div>
    </section>
}
else
{
    <section class="py-5">
        <div class="container text-center text-muted py-5">
            <i class="bi bi-box-seam fs-1 mb-3 d-block"></i>
            <p>No featured products available right now. Check back soon!</p>
        </div>
    </section>
}
