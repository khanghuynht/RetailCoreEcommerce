@{
    ViewData["Title"] = "Order Confirmed";
    var orderCode = ViewBag.OrderCode as string ?? "—";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">

            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                     style="width:80px;height:80px;background:rgba(25,135,84,.12);">
                    <i class="bi bi-check-circle-fill text-success" style="font-size:2.5rem;"></i>
                </div>
                <h2 class="fw-bold mb-1">Payment Successful!</h2>
                <p class="text-muted">Thank you for your order. We're getting it ready for you.</p>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body py-4">
                    <div class="text-muted small mb-1">Order Code</div>
                    <div class="fs-4 fw-bold text-primary">@orderCode</div>
                    <hr class="my-3" />
                    <p class="text-muted small mb-0">
                        You'll receive a confirmation email shortly.
                        Track your order using the code above.
                    </p>
                </div>
            </div>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a asp-controller="Shop" asp-action="Index" class="btn btn-primary px-4">
                    <i class="bi bi-bag me-1"></i>Continue Shopping
                </a>
            </div>

        </div>
    </div>
</div>
