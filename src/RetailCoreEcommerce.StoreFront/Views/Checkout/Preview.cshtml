@model RetailCoreEcommerce.Contracts.Models.Checkout.PreviewCheckoutResponse
@{
    ViewData["Title"] = "Checkout Preview";
}

<div class="container py-5">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-bag-check me-2" style="color:var(--accent);"></i>Checkout Preview
        </h2>
        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to Cart
        </a>
    </div>

    @if (Model.HasIssues)
    {
        <div class="alert alert-warning mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Attention:</strong> Some items in your cart have issues (price changes, low stock, or unavailability).
            Please review before placing your order.
        </div>
    }

    <div class="row g-4">

        <!-- ── Preview Items ──────────────────────────────── -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Product</th>
                                <th class="text-center">Unit Price</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-end pe-4">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                var rowClass = !item.IsAvailable ? "table-danger"
                                    : item.StockInsufficient ? "table-warning"
                                    : item.PriceChanged ? "table-info"
                                    : "";
                                <tr class="@rowClass">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-start gap-3">
                                            @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                            {
                                                <img src="@item.ThumbnailUrl"
                                                     alt="@item.ProductTitle"
                                                     class="rounded"
                                                     style="width:56px;height:56px;object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                                     style="width:56px;height:56px;flex-shrink:0;">
                                                    <i class="bi bi-image text-muted"></i>
                                                </div>
                                            }
                                            <div>
                                                <div class="fw-semibold">@item.ProductTitle</div>
                                                @if (!item.IsAvailable)
                                                {
                                                    <span class="badge bg-danger mt-1">
                                                        <i class="bi bi-x-circle me-1"></i>Unavailable
                                                    </span>
                                                }
                                                else if (item.StockInsufficient)
                                                {
                                                    <span class="badge bg-warning text-dark mt-1">
                                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                                        Only @item.AvailableStock in stock
                                                    </span>
                                                }
                                                @if (item.PriceChanged)
                                                {
                                                    <div class="small mt-1">
                                                        <span class="text-muted text-decoration-line-through me-1">
                                                            @item.CachedUnitPrice.ToString("C") $
                                                        </span>
                                                        <span class="badge bg-info text-dark">
                                                            <i class="bi bi-arrow-repeat me-1"></i>Price updated
                                                        </span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-semibold">@item.CurrentUnitPrice.ToString("C") $</span>
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end pe-4 fw-semibold">@item.SubTotal.ToString("C") $</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model.HasIssues)
            {
                <div class="mt-3">
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-pencil-square me-1"></i>Edit Cart
                    </a>
                </div>
            }
        </div>

        <!-- ── Summary ────────────────────────────────────── -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="fw-bold mb-4">Order Summary</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Items (@Model.Items.Count)</span>
                        <span>@Model.Total.ToString("C") $</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                        <span>Total</span>
                        <span style="color:var(--accent);">@Model.Total.ToString("C") $</span>
                    </div>

                    @if (Model.HasIssues)
                    {
                        <div class="alert alert-warning py-2 small mb-3">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Please resolve issues before placing your order.
                        </div>
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-warning w-100 fw-semibold">
                            <i class="bi bi-pencil-square me-1"></i>Edit Cart
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Checkout" asp-action="Payment"
                           class="btn btn-primary w-100 fw-semibold">
                            <i class="bi bi-credit-card me-2"></i>Proceed to Payment
                        </a>
                    }

                    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                        <i class="bi bi-arrow-left me-1"></i>Back to Cart
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
