@{
    ViewData["Title"] = "Payment Failed";
    var orderCode = ViewBag.OrderCode as string ?? "—";
    var orderId = ViewBag.OrderId as Guid?;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">

            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                     style="width:80px;height:80px;background:rgba(220,53,69,.12);">
                    <i class="bi bi-x-circle-fill text-danger" style="font-size:2.5rem;"></i>
                </div>
                <h2 class="fw-bold mb-1">Payment Failed</h2>
                <p class="text-muted">We couldn't process your payment. Please try again or use a different card.</p>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body py-4">
                    <div class="text-muted small mb-1">Order Reference</div>
                    <div class="fs-5 fw-semibold">@orderCode</div>
                    <hr class="my-3" />
                    <p class="text-muted small mb-0">
                        No charge has been made to your card. You can retry payment below
                        or contact us if the issue persists.
                    </p>
                </div>
            </div>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a asp-controller="Checkout" asp-action="Payment" class="btn btn-primary px-4">
                    <i class="bi bi-arrow-repeat me-1"></i>Try Again
                </a>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary px-4">
                    Continue Shopping
                </a>
            </div>

        </div>
    </div>
</div>
