<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – RetailCore</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- ── Navbar ──────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg navbar-dark" style="background-color: var(--primary);">
    <div class="container">
        <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
            Retail<span>Core</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                </li>

                <!-- Dynamic 2-level category dropdown -->
                @if (ViewBag.NavCategories is List<GetPagedCategoryResponse> { Count: > 0 } navCats)
                {
                    // Preprocess categories into parent-child structure for easier rendering
                    var navRoots = navCats.Where(c => c.ParentId == null).ToList();
                    
                    // Create a lookup for subcategories by parent ID
                    var navSubMap = navCats
                        .Where(c => c.ParentId != null)
                        .GroupBy(c => c.ParentId!.Value)
                        .ToDictionary(g => g.Key, g => g.ToList());

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            Categories
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark">
                            <li>
                                <a class="dropdown-item" asp-controller="Shop" asp-action="Index">All Products</a>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            @foreach (var parent in navRoots)
                            {
                                var subs = navSubMap.GetValueOrDefault(parent.Id);
                                <li>
                                    <a class="dropdown-item fw-semibold"
                                       asp-controller="Shop"
                                       asp-action="Index"
                                       asp-route-categoryId="@parent.Id">
                                        @parent.Name
                                    </a>
                                </li>
                                @if (subs is { Count: > 0 })
                                {
                                    @foreach (var sub in subs)
                                    {
                                        <li>
                                            <a class="dropdown-item ps-4"
                                               asp-controller="Shop"
                                               asp-action="Index"
                                               asp-route-categoryId="@sub.Id">
                                                <i class="bi bi-dash me-1 opacity-50"></i>@sub.Name
                                            </a>
                                        </li>
                                    }
                                }
                                <li><hr class="dropdown-divider" /></li>
                            }
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Shop" asp-action="Index">Shop</a>
                    </li>
                }
            </ul>

            <!-- Search form -->
            <form class="d-flex me-3" asp-controller="Shop" asp-action="Index" method="get">
                <div class="input-group">
                    <input class="form-control form-control-sm"
                           type="search"
                           name="name"
                           placeholder="Search products…"
                           style="min-width:200px;" />
                    <button class="btn btn-outline-light btn-sm" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <!-- Cart icon -->
            <a asp-controller="Cart" asp-action="Index"
               class="btn btn-outline-light btn-sm me-1"
               title="My Cart">
                <i class="bi bi-cart3"></i>
            </a>

            <!-- Auth nav -->
            @if (ViewBag.IsAuthenticated == true)
            {
                <div class="dropdown">
                    <button class="btn btn-outline-light btn-sm dropdown-toggle d-flex align-items-center gap-1"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">
                        <i class="bi bi-person-circle"></i>
                        <span>@ViewBag.UserFullName</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark mt-1">
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <div class="d-flex gap-2">
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-light btn-sm">Sign In</a>
                    <a asp-controller="Auth" asp-action="Register" class="btn btn-light btn-sm fw-semibold">Register</a>
                </div>
            }
        </div>
    </div>
</nav>

<!-- ── Page content ─────────────────────────────────────────── -->
<main>
    @if (ViewBag.ApiError is string apiError)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-0 rounded-0" role="alert">
            <div class="container">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@apiError
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }
    @RenderBody()
</main>

<!-- ── Footer ───────────────────────────────────────────────── -->
<footer class="py-5 mt-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <h5 class="fw-bold text-white mb-3">Retail<span style="color:var(--accent)">Core</span></h5>
                <p class="small">Your one-stop shop for quality products at competitive prices.</p>
            </div>
            <div class="col-md-4">
                <h6 class="fw-bold text-white mb-3">Quick Links</h6>
                <ul class="list-unstyled small">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Shop" asp-action="Index">Shop</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="fw-bold text-white mb-3">Contact</h6>
                <p class="small mb-1"><i class="bi bi-envelope me-2"></i>support@retailcore.com</p>
                <p class="small"><i class="bi bi-telephone me-2"></i>+84 123 456 789</p>
            </div>
        </div>
        <hr class="mt-4" style="border-color: rgba(255,255,255,.15);" />
        <p class="text-center small mb-0">&copy; @DateTime.Now.Year RetailCore. All rights reserved.</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

<!-- ── Toast notifications ───────────────────────────────────────── -->
@if (TempData["CartSuccess"] is string cartSuccess)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div id="toastSuccess" class="toast align-items-center text-bg-success border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-cart-check-fill me-2"></i>@cartSuccess
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
    <script>
        (function () {
            var el = document.getElementById('toastSuccess');
            if (el) bootstrap.Toast.getOrCreateInstance(el, { delay: 3000 }).show();
        })();
    </script>
}
@if (TempData["CartError"] is string cartError)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div id="toastError" class="toast align-items-center text-bg-danger border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@cartError
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
    <script>
        (function () {
            var el = document.getElementById('toastError');
            if (el) bootstrap.Toast.getOrCreateInstance(el, { delay: 4000 }).show();
        })();
    </script>
}
</body>
</html>
