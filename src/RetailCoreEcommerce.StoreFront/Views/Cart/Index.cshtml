@model RetailCoreEcommerce.Contracts.Models.Cart.Cart
@{
    ViewData["Title"] = "My Cart";
    var isEmpty = Model.Items.Count == 0;
}

<div class="container py-5">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-cart3 me-2" style="color:var(--accent);"></i>My Cart
        </h2>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Continue Shopping
        </a>
    </div>

    @if (isEmpty)
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x" style="font-size:5rem; color:var(--accent); opacity:.5;"></i>
            <h4 class="mt-3 text-muted">Your cart is empty</h4>
            <p class="text-muted">Browse our products and add something you like!</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary mt-2">
                <i class="bi bi-bag me-1"></i>Shop Now
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">

            <!-- ── Cart Items ─────────────────────────────────── -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Product</th>
                                    <th class="text-center">Price</th>
                                    <th class="text-center" style="width:160px;">Quantity</th>
                                    <th class="text-end">Subtotal</th>
                                    <th class="text-end pe-4"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-3">
                                                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                                {
                                                    <img src="@item.ThumbnailUrl"
                                                         alt="@item.ProductTitle"
                                                         class="rounded"
                                                         style="width:56px;height:56px;object-fit:cover;" />
                                                }
                                                else
                                                {
                                                    <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                                         style="width:56px;height:56px;">
                                                        <i class="bi bi-image text-muted"></i>
                                                    </div>
                                                }
                                                <span class="fw-semibold">@item.ProductTitle</span>
                                            </div>
                                        </td>
                                        <td class="text-center">@item.UnitPrice.ToString("C") $</td>
                                        <td class="text-center">
                                            <form asp-action="UpdateItem" method="post" class="d-flex align-items-center justify-content-center gap-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="number"
                                                       name="quantity"
                                                       value="@item.Quantity"
                                                       min="1"
                                                       max="99"
                                                       class="form-control form-control-sm text-center"
                                                       style="width:64px;" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Update">
                                                    <i class="bi bi-arrow-repeat"></i>
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-end fw-semibold">@item.SubTotal.ToString("C") $</td>
                                        <td class="text-end pe-4">
                                            <form asp-action="RemoveItem" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        title="Remove"
                                                        onclick="return confirm('Remove this item?')">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Clear cart -->
                <div class="mt-3 text-end">
                    <form asp-action="Clear" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-outline-danger btn-sm"
                                onclick="return confirm('Clear all items from your cart?')">
                            <i class="bi bi-trash3 me-1"></i>Clear Cart
                        </button>
                    </form>
                </div>
            </div>

            <!-- ──     Order Summary ──────────────────────────────── -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="fw-bold mb-4">Order Summary</h5>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Items (@Model.Items.Count)</span>
                            <span>@Model.Total.ToString("C") $</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Shipping</span>
                            <span class="text-success">Free</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                            <span>Total</span>
                            <span style="color:var(--accent);">@Model.Total.ToString("C") $</span>
                        </div>

                        <a asp-controller="Checkout" asp-action="Preview" class="btn btn-primary w-100 fw-semibold">
                            <i class="bi bi-bag-check me-2"></i>Preview Checkout
                        </a>
                        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                        </a>
                    </div>
                </div>

                <p class="text-muted small text-center mt-3">
                    <i class="bi bi-shield-check me-1"></i>Secure checkout guaranteed
                </p>
            </div>

        </div>
    }
</div>
